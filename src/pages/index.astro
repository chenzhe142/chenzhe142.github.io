---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 680px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.feed-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}

			.feed-item {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 2rem;
			}

			.feed-item:last-child {
				border-bottom: none;
			}

			/* 🌟 将包裹层改为 div，因为里面要放独立的标签 a 链接，HTML 规范不允许 a 标签嵌套 a 标签 */
			.feed-card {
				display: flex;
				flex-direction: row-reverse;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1.5rem;
			}

			.feed-content {
				flex: 1;
			}

			/* 🌟 让标题自带整块卡片的点击跳转链接 */
			.title-link {
				text-decoration: none;
				display: block;
			}

			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				font-size: 1.4rem;
				line-height: 1.4;
				transition: color 0.2s ease;
			}

			.description {
				margin: 0 0 0.75rem 0;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* 🌟 底部元数据布局（日期 + 标签） */
			.feed-meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem;
			}

			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}

			/* 🌟 可点击的 Tags 样式 */
			.tags-container {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}

			.tag {
				display: inline-block;
				padding: 0.15rem 0.5rem;
				background-color: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 4px;
				font-size: 0.75rem;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.tag:hover {
				background-color: var(--accent);
				color: #fff;
			}

			/* 🌟 图片也包裹一个文章链接 */
			.feed-image-link {
				width: 180px;
				flex-shrink: 0;
				display: block;
			}

			.feed-image-link img {
				width: 100%;
				height: 110px;
				object-fit: cover;
				border-radius: 8px;
				transition:
					box-shadow 0.2s ease,
					transform 0.2s ease;
			}

			/* Hover 交互效果升级 */
			.title-link:hover .title {
				color: var(--accent);
			}
			.feed-image-link:hover img {
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
			}

			@media (max-width: 600px) {
				.feed-list {
					gap: 1.5rem;
				}
				.feed-item {
					padding-bottom: 1.5rem;
				}
				.feed-card {
					flex-direction: column;
					gap: 1rem;
				}
				.feed-image-link {
					width: 100%;
				}
				.feed-image-link img {
					height: 180px;
				}
				.title {
					font-size: 1.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul class="feed-list">
					{
						posts.map((post) => (
							<li class="feed-item">
								<div class="feed-card">
									{/* 右侧配图（可点击进入文章） */}
									{/* {post.data.heroImage && (
										<a
											href={`/blog/${post.id}/`}
											class="feed-image-link"
										>
											<Image
												width={360}
												height={220}
												src={post.data.heroImage}
												alt=""
											/>
										</a>
									)} */}

									{/* 左侧文字 */}
									<div class="feed-content">
										<a
											href={`/blog/${post.id}/`}
											class="title-link"
										>
											<h2 class="title">
												{post.data.title}
											</h2>
										</a>
										{post.data.description && (
											<p class="description">
												{post.data.description}
											</p>
										)}

										{/* 元数据区域：包含日期和可点击标签 */}
										<div class="feed-meta">
											<p class="date">
												<FormattedDate
													date={post.data.pubDate}
												/>
											</p>

											{post.data.tags &&
												post.data.tags.length > 0 && (
													<div class="tags-container">
														{post.data.tags.map(
															(tag: string) => (
																<a
																	href={`/tags/${tag}/`}
																	class="tag"
																>
																	#{tag}
																</a>
															),
														)}
													</div>
												)}
										</div>
									</div>
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
